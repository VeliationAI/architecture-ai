# OpenAI API key for architecture generation and review
OPENAI_API_KEY=sk-...

# Model to use (defaults to gpt-4o-mini if unset)
OPENAI_MODEL=gpt-4o-mini

# Set to "true" to use mock responses without calling OpenAI (useful for local dev)
USE_MOCK_LLM=false

# Web app URL (for MCP resource links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo video on the landing page (YouTube, Loom, or direct .mp4/.webm URL)
# Defaults to https://youtu.be/WgZOvAV58i8 if unset
NEXT_PUBLIC_DEMO_VIDEO_URL=https://youtu.be/WgZOvAV58i8
